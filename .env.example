# ── CLIENT-SIDE PUBLIC VARS ─────────────────────────────────
# These are bundled into the app binary — never put secrets here.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_NUTRITIONIX_APP_ID=
EXPO_PUBLIC_NUTRITIONIX_APP_KEY=
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=
EXPO_PUBLIC_APP_BUNDLE_ID=com.yourdomain.apex
EXPO_PUBLIC_EAS_PROJECT_ID=
EXPO_PUBLIC_SENTRY_DSN=

# ── NATIVE BUILD-TIME KEYS (not bundled in JS, injected into native manifests) ──
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_IOS_API_KEY=

# ── SERVER-SIDE SECRETS ──────────────────────────────────────
# Used in Supabase Edge Functions and CI/CD only. Never in client code.
ANTHROPIC_API_KEY=
REVENUECAT_IOS_KEY=

# ── SENTRY (CI build-time only) ──────────────────────────────
# Used by the @sentry/react-native/expo plugin to upload source maps.
SENTRY_ORG=bodybyreason
SENTRY_PROJECT=apex
SENTRY_AUTH_TOKEN=

# ── SUPABASE CLI (CI deploy only) ────────────────────────────
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
