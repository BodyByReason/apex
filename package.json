{
  "name": "apex",
  "version": "1.0.5",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "voice-proxy": "node scripts/realtime-voice-proxy/server.mjs",
    "postinstall": "node -e \"const fs=require('fs');const p='node_modules/@livekit/react-native-webrtc/package.json';const j=JSON.parse(fs.readFileSync(p,'utf8'));j['react-native']='lib/commonjs/index.js';fs.writeFileSync(p,JSON.stringify(j,null,2));\" && node scripts/patch-livekit-events.js && node scripts/patch-expo-sharing.js && node scripts/patch-health-connect-crash.js"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^13.0.0",
    "@elevenlabs/react-native": "1.1.3",
    "@expo-google-fonts/bebas-neue": "^0.4.1",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/space-mono": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@fal-ai/client": "^1.9.6",
    "@kingstinct/react-native-healthkit": "^14.0.0",
    "@livekit/react-native": "2.9.2",
    "@livekit/react-native-expo-plugin": "^1.0.2",
    "@livekit/react-native-webrtc": "137.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "2.0.2",
    "@stripe/stripe-react-native": "0.50.3",
    "@supabase/supabase-js": "^2.102.1",
    "expo": "^54.0.33",
    "expo-asset": "~12.0.12",
    "expo-av": "~16.0.8",
    "expo-build-properties": "^55.0.13",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.16",
    "i18next": "^26.0.4",
    "livekit-client": "2.15.16",
    "posthog-react-native": "^4.41.0",
    "react": "19.1.0",
    "react-i18next": "^17.0.2",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-health-connect": "^3.5.0",
    "react-native-incall-manager": "^4.2.1",
    "react-native-maps": "1.20.1",
    "react-native-nitro-modules": "^0.35.4",
    "react-native-purchases": "^9.15.2",
    "react-native-purchases-ui": "^9.15.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-webview": "13.15.0",
    "resolve-from": "^5.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "docx": "^9.7.1",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react-native-worklets": "^0.5.1",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "setupFiles": [
      "./src/__tests__/setup.ts"
    ]
  },
  "overrides": {
    "livekit-client": "2.15.16"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-webrtc"
        ]
      }
    }
  }
}
